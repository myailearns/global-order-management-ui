{
  "name": "gom-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "storybook": "ng run gom-ui:storybook",
    "build-storybook": "ng run gom-ui:build-storybook"
